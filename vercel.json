{
  "buildCommand": "pnpm run build:prod",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/", "destination": "/iacm/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/iacm/(.*)", "destination": "/iacm/index.html" },
    { "source": "/iacm-sales-enablement", "destination": "/iacm/index.html" },
    { "source": "/login/callback{/}?", "destination": "/iacm/index.html" }
  ]

}
